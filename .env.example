# Gemini API key — get from the course portal
GEMINI_KEY=your_key_here

# Your student ID — shows in the app footer on every screenshot
STUDENT_ID=60306991

# ── CI/CD note ────────────────────────────────────────────────────────────────
# GEMINI_KEY and STUDENT_ID are set as Environment Variables on your Render
# service (Settings → Environment). They are NOT GitHub Secrets.
# GitHub Secrets only store: DOCKERHUB_USERNAME, DOCKERHUB_TOKEN, RENDER_DEPLOY_URL
